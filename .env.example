# Plantilla — copia a .env.local y rellena. NUNCA commitear .env.local.
#
# Camino rápido (recomendado, ~30s):
#   vercel link              # selecciona el proyecto pizza-demo
#   vercel env pull .env.local
#   # luego edita NEXT_PUBLIC_APP_URL a http://localhost:3000 (ver abajo)
#
# Camino manual: rellena cada bloque con los valores de tu Supabase + Meta + Vercel.

# --- Modo demo (opcional) ---
# Si lo activas, la app corre con fixtures en memoria — útil para mostrar UI sin
# tocar Supabase. Las suscripciones Realtime NO funcionan en demo mode (apunta a
# una URL placeholder). Déjalo vacío o en "false" para conectar a Supabase real.
NEXT_PUBLIC_DEMO_MODE=

# --- App ---
# En local: http://localhost:3000  ·  En prod: https://<tu-dominio>
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
# Studio → Settings → API: URL del proyecto + anon public + service_role.
# El service_role NUNCA se expone al cliente; solo lo usa el código server.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Tokens HMAC del catálogo (links /pedir/[token]) ---
# Generar con:  openssl rand -base64 48
ORDER_TOKEN_SECRET=

# --- WhatsApp Cloud API (Meta) ---
# Solo necesario cuando Meta esté aprobado (3-4 semanas de trámite).
# En desarrollo puedes dejarlos con cualquier string (los validators piden
# min(1) — ver src/lib/env.ts). Sin Meta aprobado el webhook no se dispara.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
META_GRAPH_API_VERSION=v23.0

# --- PrintNode (opcional, fuera del MVP hasta tener ticketera real) ---
PRINTNODE_API_KEY=
PRINTNODE_PRINTER_ID=

# --- Cron F8 alertas de retraso ---
# Generar con:  openssl rand -base64 32
# Mismo valor debe estar en cron_config.cron_secret en Supabase Studio.
CRON_SECRET=
